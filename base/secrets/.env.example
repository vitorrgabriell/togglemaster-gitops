# =============================================================================
# SECRETS - togglemaster
# =============================================================================
# Copie este arquivo para .env e preencha os valores reais:
#   cp .env.example .env
#
# Para aplicar no cluster:
#   bash apply-secrets.sh
#
# O arquivo .env é gitignored — nunca commite valores reais.
# =============================================================================

# --- Auth Service ---
# Endpoint do RDS do auth-service (ex: auth-db.abc123.us-east-1.rds.amazonaws.com)
AUTH_DB_PASSWORD=<AUTH_DB_PASSWORD>
AUTH_RDS_ENDPOINT=togglemaster-auth-db.c2n8q2se2yio.us-east-1.rds.amazonaws.com
# Chave mestra para assinatura/criptografia — gere com: openssl rand -hex 32
AUTH_MASTER_KEY=<MASTER_KEY>

# --- Flag Service ---
# Endpoint do RDS do flag-service (ex: flag-db.abc123.us-east-1.rds.amazonaws.com)
FLAG_DB_PASSWORD=<FLAG_DB_PASSWORD>
FLAG_RDS_ENDPOINT=togglemaster-flag-db.c2n8q2se2yio.us-east-1.rds.amazonaws.com

# --- Targeting Service ---
# Endpoint do RDS do targeting-service (ex: targeting-db.abc123.us-east-1.rds.amazonaws.com)
TARGETING_DB_PASSWORD=<TARGETING_DB_PASSWORD>
TARGETING_RDS_ENDPOINT=togglemaster-targeting-db.c2n8q2se2yio.us-east-1.rds.amazonaws.com

# --- Redis ---
# Endpoint do ElastiCache/Redis (ex: my-cluster.abc123.ng.0001.use1.cache.amazonaws.com)
REDIS_ENDPOINT=<REDIS_ENDPOINT>

# --- AWS ---
# Região AWS (ex: us-east-1)
AWS_REGION=us-east-1
# URL completa da fila SQS (ex: https://sqs.us-east-1.amazonaws.com/<ACCOUNT_ID>/<QUEUE_NAME>)
AWS_SQS_URL=<AWS_SQS_URL>
# Credenciais IAM com permissões de SQS e DynamoDB
AWS_ACCESS_KEY_ID=<AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<AWS_SECRET_ACCESS_KEY>
# Session Token — necessário apenas para credenciais temporárias (STS/AssumeRole); deixe vazio se usar permanentes
AWS_SESSION_TOKEN=<AWS_SESSION_TOKEN>
